# Telegram Bot Configuration
TELEGRAM_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# Environment Variables
ASSETS=BTC,ETH
DCA_THRESHOLD=0.05
CONFIDENCE_MIN=0.80

# Deribit API (optional, not needed for public endpoints)
# DERIBIT_KEY=
# DERIBIT_SECRET=

# Cloudflare KV Namespace ID (set in wrangler.toml)
# RL_STATE KV binding ID: your-kv-id-here
