# ── Variables Frontend Vite (exposées au navigateur) ─────────────────────────

# CryptoQuant — Exchange Flows BTC/ETH (clé gratuite sur https://cryptoquant.com)
# Sans cette clé, la section "Exchange Flows" de la page On-Chain est désactivée.
VITE_CRYPTOQUANT_API_KEY=your_free_cryptoquant_api_key

# Anthropic — Insights IA (Claude haiku) (clé sur https://console.anthropic.com)
# Sans cette clé, des insights statiques de remplacement sont utilisés.
# VITE_ANTHROPIC_API_KEY=your_anthropic_api_key

# Deribit API (optional, not needed for public endpoints)
# DERIBIT_KEY=
# DERIBIT_SECRET=

# ── Mode maintenance ──────────────────────────────────────────────────────────

# Mettre à "true" pour afficher la page de maintenance à la place de l'application.
# VITE_MAINTENANCE_MODE=false

# Message affiché sur la page de maintenance (optionnel).
# VITE_MAINTENANCE_MESSAGE=Veridex est temporairement indisponible le temps d'une mise à jour.

# Heure de retour estimée affichée sur la page de maintenance (optionnel).
# VITE_MAINTENANCE_ESTIMATE=dans quelques minutes

# ── Variables Backend Node.js (non exposées au navigateur) ───────────────────

# Mettre à "true" pour passer le backend en mode maintenance (renvoie 503 sur toutes les routes API).
# MAINTENANCE_MODE=false

# Port d'écoute du serveur Express (défaut : 3000)
# PORT=3000

# URL Deribit API (optionnel — remplace l'URL par défaut)
# DERIBIT_API_URL=https://www.deribit.com/api/v2/public

# ── Data Collection ───────────────────────────────────────────────────────────

# URL de connexion PostgreSQL (production).
# En production (NODE_ENV=production), cette variable est OBLIGATOIRE.
# Si absente, le backend refuse de démarrer (exit 1).
# En développement, SQLite local est utilisé si DATABASE_URL est absent.
# DATABASE_URL=postgresql://user:password@host:5432/veridex

# PostgreSQL SSL mode (optionnel).
# Par défaut : SSL activé avec rejectUnauthorized=false (compatible Railway / certificats auto-signés).
# Valeurs possibles :
#   (vide)       : SSL requis, certificat auto-signé accepté (par défaut — Railway, Supabase, Render…)
#   verify-full  : SSL avec vérification complète du certificat CA (nécessite PGSSLROOTCERT)
#   disable      : SSL désactivé (Postgres local sans SSL uniquement)
# PGSSLMODE=

# Mettre à "false" pour désactiver le collecteur de données au démarrage.
# ENABLE_COLLECTOR=true

# URL WebSocket Deribit (optionnel — remplace l'URL par défaut)
# DERIBIT_WS_URL=wss://www.deribit.com/ws/api/v2

# Niveau de log (info | debug). En mode debug, tous les messages WebSocket sont loggués.
# LOG_LEVEL=info
